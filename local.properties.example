# Copia este archivo a local.properties (o agrega estas líneas a tu local.properties existente).
# local.properties no se sube a git.

# URL base de la API (debe terminar con /)
# En emulador Android usa 10.0.2.2 en lugar de 127.0.0.1 para apuntar a tu PC.
api.base.url=http://127.0.0.1:8000/api/

# Ejemplo para emulador:
# api.base.url=http://10.0.2.2:8000/api/
